{
  "name": "openwhisper-tauri",
  "private": true,
  "version": "0.5.0",
  "description": "OpenWhisper — local-first hotkey dictation for macOS and Windows.",
  "license": "MIT",
  "author": "Jimmi Joensson",
  "homepage": "https://github.com/jimmi-joensson/OpenWhisper",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jimmi-joensson/OpenWhisper.git"
  },
  "bugs": {
    "url": "https://github.com/jimmi-joensson/OpenWhisper/issues"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "dev:tauri": "node scripts/dev-run.cjs",
    "setup:ort": "node scripts/fetch-ort.cjs",
    "vendor:natives": "node scripts/vendor-natives.cjs",
    "notarize:mac": "node scripts/notarize-mac.cjs",
    "release:mac": "pnpm tauri build && pnpm notarize:mac",
    "test:ui": "playwright test",
    "test:ui:ui": "playwright test --ui",
    "test:ui:headed": "playwright test --headed",
    "test:ui:debug": "playwright test --debug",
    "pw:open": "playwright-cli -s=ow open http://localhost:1420 && playwright-cli -s=ow run-code --filename=scripts/pw-shim.js && playwright-cli -s=ow reload",
    "pw:close": "playwright-cli -s=ow close"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@fontsource-variable/geist": "5.2.8",
    "@radix-ui/react-slot": "1.2.4",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-autostart": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "lucide-react": "1.11.0",
    "radix-ui": "1.4.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "shadcn": "4.5.0",
    "tailwind-merge": "3.5.0",
    "tw-animate-css": "1.4.0"
  },
  "devDependencies": {
    "@playwright/cli": "0.1.9",
    "@playwright/test": "1.59.1",
    "@tailwindcss/vite": "4.2.4",
    "@tauri-apps/cli": "^2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "tailwindcss": "4.2.4",
    "typescript": "~5.8.3",
    "vite": "^7.0.4"
  }
}
