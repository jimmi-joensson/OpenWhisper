# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.Spotlight-V100
.Trashes

# Editors / IDEs
.idea/
.vscode/
*.swp
*.swo
*.sublime-project
*.sublime-workspace
.zed/

# Environment / secrets
.env
.env.*
!.env.example
*.pem
*.key
.secrets/

# Logs
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Node / JS
node_modules/
dist/
build/
out/
.next/
.nuxt/

# TypeScript incremental build cache
*.tsbuildinfo
.turbo/
.cache/
coverage/
.pnpm-store/
.yarn/cache
.yarn/install-state.gz

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/

# Rust
target/
Cargo.lock.bak

# swift-bridge codegen output (regenerated by core/build.rs whenever the
# `macos-shell` feature is on — only the archived SwiftUI shell consumes it).
archive/macos/Generated/
apps/macos/Generated/

# Swift / Xcode
DerivedData/
*.xcworkspace/xcuserdata/
*.xcodeproj/xcuserdata/
*.xcodeproj/project.xcworkspace/xcuserdata/
*.pbxuser
*.mode1v3
*.mode2v3
*.perspectivev3
.build/
Packages/
Package.resolved

# Retired SwiftUI shell (archive/macos). Generated Xcode project + build
# artifacts stay ignored; reproducible via xcodegen if you ever need to
# build the historical shell.
archive/macos/OpenWhisper.xcodeproj/
archive/macos/Generated/
archive/macos/Vendor/
archive/macos/Resources/Info.plist

# .NET / C# (Windows shell + spikes)
bin/
obj/
*.user
*.suo
*.userprefs

# Tauri / Electron
src-tauri/target/
release/

# Release packaging output
dist/
build/

# Local models / weights / audio assets (large binaries)
# Note: models/ is tracked (docs, conversion scripts); only actual weight files are ignored.
*.gguf
*.bin
*.pt
*.pth
*.onnx
*.mlmodel
*.mlmodelc/
*.mlpackage/
*.safetensors
recordings/
*.wav
*.mp3
*.m4a
*.flac
!docs/**/*.wav
!tests/**/fixtures/**
!cli/tests/**/fixtures/**
!archive/macos/Resources/samples/**
# Bench clips + reference transcripts may contain PII / personal voice —
# always local, never committed.
scripts/bench/clips/*.wav
scripts/bench/clips/*.ref.txt
# Per-host benchmark output. Format defined by smoke-with-wpr.ps1 /
# smoke-with-powermetrics.sh; numbers are machine-specific and noisy
# across developers — keep them local.
scripts/bench/results/

# SwiftPM build artifacts for the FluidAudio Rust↔Swift bridge.
core/swift/**/.build/
core/swift/**/.swiftpm/

# Claude Code project-local state (scheduled task locks, etc.) — but
# project skills, project-shared settings.json, and project hooks are
# part of the repo. settings.local.json stays per-user.
.claude/*
!.claude/skills/
!.claude/hooks/
!.claude/settings.json

# Misc
tmp/
temp/
.DS_Store?
Thumbs.db
