<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="OpenWhisper.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:OpenWhisper"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="OpenWhisper"
    mc:Ignorable="d">
    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid Padding="24,0,24,24" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TitleBar x:Name="AppTitleBar" Title="OpenWhisper" Grid.Row="0">
            <TitleBar.IconSource>
                <ImageIconSource ImageSource="Assets/AppIcon.ico" />
            </TitleBar.IconSource>
        </TitleBar>

        <TextBlock Grid.Row="1"
                   x:Name="HeaderText"
                   FontSize="32"
                   FontWeight="SemiBold"
                   Text="OpenWhisper" />

        <TextBlock Grid.Row="2"
                   x:Name="SubtitleText"
                   Opacity="0.7"
                   Text="Tap Record or press Left Ctrl + Space anywhere." />

        <Button Grid.Row="3"
                x:Name="RecordButton"
                Click="OnRecordClick"
                Height="48"
                HorizontalAlignment="Stretch"
                Style="{StaticResource AccentButtonStyle}">
            <TextBlock x:Name="RecordButtonText" Text="Start recording" FontSize="16" />
        </Button>

        <ProgressBar Grid.Row="4"
                     x:Name="LevelMeter"
                     Minimum="0"
                     Maximum="1"
                     Value="0"
                     IsIndeterminate="False"
                     ShowPaused="False"
                     ShowError="False" />

        <ScrollViewer Grid.Row="5"
                      VerticalScrollBarVisibility="Auto"
                      Padding="0"
                      Margin="0,8,0,0">
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16">
                <TextBlock x:Name="TranscriptText"
                           FontSize="15"
                           TextWrapping="Wrap"
                           IsTextSelectionEnabled="True"
                           Text="Transcript will appear here." />
            </Border>
        </ScrollViewer>

        <TextBlock Grid.Row="6"
                   x:Name="StatusText"
                   Opacity="0.7"
                   FontSize="12"
                   Text="idle" />
    </Grid>
</Window>
