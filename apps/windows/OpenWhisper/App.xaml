<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="OpenWhisper.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:system="using:System"
    xmlns:local="using:OpenWhisper">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <!--
                OpenWhisper shared identity tokens. Authority: docs/design/identity-tokens.md.
                Don't edit values here without updating the spec.
            -->

            <!-- Brand color -->
            <Color x:Key="OpenWhisperRecordingColor">#FFE07000</Color>
            <SolidColorBrush x:Key="OpenWhisperRecordingBrush" Color="{StaticResource OpenWhisperRecordingColor}" />

            <!-- Pill neutrals (alpha baked into color — applied over Acrylic) -->
            <SolidColorBrush x:Key="PillBaseBrush" Color="#8C000000" />            <!-- black 0.55 -->
            <SolidColorBrush x:Key="PillBorderBrush" Color="#14FFFFFF" />          <!-- white 0.08 -->
            <SolidColorBrush x:Key="PillIdleDotBrush" Color="#66FFFFFF" />         <!-- white 0.40 -->
            <SolidColorBrush x:Key="LevelMeterInactiveBrush" Color="#59808080" />  <!-- gray  0.35 -->

            <!-- Transcript + banner surfaces -->
            <SolidColorBrush x:Key="TranscriptBackgroundBrush" Color="#33000000" />   <!-- black 0.20 -->
            <SolidColorBrush x:Key="InfoBannerBackgroundBrush" Color="#260078D4" />   <!-- blue  0.15 -->
            <SolidColorBrush x:Key="InfoBannerBorderBrush" Color="#590078D4" />       <!-- blue  0.35 -->

            <!-- Corner radii -->
            <CornerRadius x:Key="PillCornerRadius">11</CornerRadius>
            <CornerRadius x:Key="LevelMeterBarCornerRadius">1.5</CornerRadius>
            <CornerRadius x:Key="TranscriptCornerRadius">6</CornerRadius>
            <CornerRadius x:Key="InfoBannerCornerRadius">8</CornerRadius>

            <!-- Type scale -->
            <x:Double x:Key="HeaderFontSize">32</x:Double>
            <x:Double x:Key="HintFontSize">14</x:Double>
            <x:Double x:Key="BodyFontSize">15</x:Double>
            <x:Double x:Key="CaptionFontSize">12</x:Double>
            <x:Double x:Key="TertiaryOpacity">0.55</x:Double>
            <x:Double x:Key="SecondaryOpacity">0.7</x:Double>
            <FontFamily x:Key="MonospaceFontFamily">Consolas, Cascadia Mono, Courier New</FontFamily>

            <!-- Pill geometry -->
            <x:Double x:Key="PillWidth">70</x:Double>
            <x:Double x:Key="PillHeight">22</x:Double>
            <x:Double x:Key="PillGapAboveTaskbar">14</x:Double>
            <x:Double x:Key="PillItemSpacing">4</x:Double>
            <Thickness x:Key="PillPadding">8,5,8,5</Thickness>
            <x:Double x:Key="PillBorderThickness">1</x:Double>

            <!-- Idle dots -->
            <x:Double x:Key="IdleDotSize">3</x:Double>
            <x:Double x:Key="IdleDotSpacing">3</x:Double>

            <!-- Level meter (shared math) -->
            <x:Double x:Key="LevelMeterFloorDb">-55</x:Double>
            <x:Double x:Key="LevelMeterBarSpacing">2</x:Double>
            <x:Double x:Key="LevelMeterBarMinHeight">3</x:Double>

            <!-- Level meter (pill variant) -->
            <x:Int32 x:Key="PillLevelMeterBarCount">12</x:Int32>
            <x:Double x:Key="PillLevelMeterHeight">10</x:Double>

            <!-- Level meter (main-window variant) -->
            <x:Int32 x:Key="MainLevelMeterBarCount">32</x:Int32>
            <x:Double x:Key="MainLevelMeterHeight">36</x:Double>

            <!-- Motion -->
            <x:Int32 x:Key="LevelMeterPollIntervalMs">50</x:Int32>
            <x:Int32 x:Key="GraceReturnToIdleMs">250</x:Int32>

        </ResourceDictionary>
    </Application.Resources>
</Application>
