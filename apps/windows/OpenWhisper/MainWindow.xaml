<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="OpenWhisper.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:OpenWhisper"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="OpenWhisper"
    mc:Ignorable="d">
    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid Padding="24,0,24,24" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" /> <!-- 0 TitleBar -->
            <RowDefinition Height="Auto" /> <!-- 1 Header -->
            <RowDefinition Height="Auto" /> <!-- 2 Subtitle -->
            <RowDefinition Height="Auto" /> <!-- 3 Model load bar -->
            <RowDefinition Height="Auto" /> <!-- 4 Health banner -->
            <RowDefinition Height="Auto" /> <!-- 5 Record button -->
            <RowDefinition Height="Auto" /> <!-- 6 Level meter -->
            <RowDefinition Height="*" />    <!-- 7 Transcript -->
            <RowDefinition Height="Auto" /> <!-- 8 Status -->
        </Grid.RowDefinitions>

        <TitleBar Grid.Row="0" x:Name="AppTitleBar" Title="OpenWhisper">
            <TitleBar.IconSource>
                <ImageIconSource ImageSource="Assets/AppIcon.ico" />
            </TitleBar.IconSource>
        </TitleBar>

        <TextBlock Grid.Row="1"
                   x:Name="HeaderText"
                   FontSize="32"
                   FontWeight="SemiBold"
                   Text="OpenWhisper" />

        <TextBlock Grid.Row="2"
                   x:Name="SubtitleText"
                   Opacity="0.7"
                   Text="Tap Record or press Left Ctrl + Space anywhere." />

        <InfoBar Grid.Row="3"
                 x:Name="ModelLoadBar"
                 IsOpen="False"
                 Severity="Informational"
                 IsClosable="False"
                 Title="Preparing Parakeet v3 (multilingual)…">
            <InfoBar.Content>
                <ProgressBar x:Name="ModelLoadProgress"
                             Minimum="0"
                             Maximum="100"
                             Value="0"
                             IsIndeterminate="True"
                             Margin="0,8,0,4" />
            </InfoBar.Content>
        </InfoBar>

        <!-- Health banner: blue info panel shown when a startup probe fails
             (e.g. another app owns the Ctrl+Space hotkey). Mirrors the Mac
             restart banner's visual language via the shared InfoBanner
             tokens in App.xaml. Auto-hides on successful retry. -->
        <Border Grid.Row="4"
                x:Name="HealthBanner"
                Visibility="Collapsed"
                Background="{StaticResource InfoBannerBackgroundBrush}"
                BorderBrush="{StaticResource InfoBannerBorderBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource InfoBannerCornerRadius}"
                Padding="12,10,12,10">
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <FontIcon Grid.Column="0"
                          Glyph="&#xE946;"
                          FontSize="16"
                          VerticalAlignment="Center" />
                <TextBlock Grid.Column="1"
                           x:Name="HealthBannerText"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap" />
                <Button Grid.Column="2"
                        x:Name="HealthBannerAction"
                        Click="OnHealthBannerAction"
                        Content="Retry"
                        Style="{StaticResource AccentButtonStyle}" />
            </Grid>
        </Border>

        <Button Grid.Row="5"
                x:Name="RecordButton"
                Click="OnRecordClick"
                Height="48"
                HorizontalAlignment="Stretch"
                Style="{StaticResource AccentButtonStyle}">
            <TextBlock x:Name="RecordButtonText" Text="Start recording" FontSize="16" />
        </Button>

        <ProgressBar Grid.Row="6"
                     x:Name="LevelMeter"
                     Minimum="0"
                     Maximum="1"
                     Value="0"
                     IsIndeterminate="False"
                     ShowPaused="False"
                     ShowError="False" />

        <TextBox Grid.Row="7"
                 x:Name="TranscriptText"
                 Margin="0,8,0,0"
                 FontSize="15"
                 TextWrapping="Wrap"
                 AcceptsReturn="True"
                 IsReadOnly="True"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 PlaceholderText="Transcript will appear here." />

        <TextBlock Grid.Row="8"
                   x:Name="StatusText"
                   Opacity="0.7"
                   FontSize="12"
                   Text="idle" />
    </Grid>
</Window>
