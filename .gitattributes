# Cross-platform line endings: store LF in repo and check out LF on every
# platform. Mac and Linux already work that way; Windows devs see LF in their
# working tree too — modern editors (VS Code, JetBrains, Vim, Notepad) handle
# LF fine, and matching the repo prevents the "warning: LF will be replaced
# by CRLF" churn that re-stages files on every git operation.
* text=auto eol=lf

# Windows-specific scripts must keep CRLF or cmd.exe / PowerShell mis-parse them.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# SVG is XML — keep as text/LF.
*.svg text eol=lf

# Common binaries — explicit so git never tries to convert.
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.icns binary
*.pdf  binary
*.zip  binary
*.gz   binary
*.tar  binary
*.7z   binary
*.exe  binary
*.dll  binary
